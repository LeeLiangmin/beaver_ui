{
  "name": "beaver",
  "version": "1.0.0",
  "description": "Beaver - Daily Work Assistant",
  "author": "Beaver",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.node.json -w\" \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build && tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "generate-ico": "node scripts/generate-ico.mjs",
    "set-exe-icon": "node scripts/set-exe-icon.mjs",
    "package": "npm run build && npm run generate-ico && electron-builder && npm run set-exe-icon",
    "package:direct": "electron-builder && npm run set-exe-icon",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "better-sqlite3": "^12.11.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.575.0",
    "lunar-javascript": "^1.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "undici": "^8.6.0",
    "winreg": "^1.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/winreg": "^1.2.36",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.6",
    "electron-reloader": "^1.2.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "node-gyp": "^11.2.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.0"
  }
}
