{
  "name": "beaver",
  "version": "1.0.0",
  "description": "Beaver - Daily Work Assistant",
  "author": "Beaver",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.node.json -w\" \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build && tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "generate-ico": "node scripts/generate-ico.mjs",
    "set-exe-icon": "node scripts/set-exe-icon.mjs",
    "package": "npm run build && npm run generate-ico && electron-builder && npm run set-exe-icon",
    "package:direct": "electron-builder && npm run set-exe-icon",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^0.575.0",
    "lunar-javascript": "^1.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winreg": "^1.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/winreg": "^1.2.36",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "electron-reloader": "^1.2.3",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.0.0",
    "node-gyp": "^11.2.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
